# ── Export to Markdown ─────────────────────────────────────────────────────────
def export_projects():
    db       = load_db()
    projects = sorted(db["projects"], key=lambda p: (p["year"], p["month"]))

    if not projects:
        print(colorize("\n  No projects to export.\n", GRAY + DIM))
        _footer()
        return

    today    = date.today().strftime("%Y-%m-%d")
    filename = f"xp-export-{today}.md"
    filepath = Path.cwd() / filename

    lines = []
    lines.append(f"# Experience Export\n")
    lines.append(f"*Generated on {today} · {len(projects)} project{'s' if len(projects) != 1 else ''}*\n")
    lines.append("")

    for p in projects:
        lines.append(f"---\n")
        lines.append(f"## {p['name']}\n")
        lines.append(f"**Client:** {p['client']}  ")
        lines.append(f"**Employer:** {p['employer']}  ")
        if p.get("role"):
            lines.append(f"**Role:** {p['role']}  ")
        lines.append(f"**Period:** {fmt_period(p['month'], p['year'])}  ")
        lines.append(f"**Industry:** {p['industry']}\n")

        if p.get("functionals"):
            lines.append(f"**Functional areas:** {', '.join(p['functionals'])}\n")
        if p.get("skills"):
            lines.append(f"**Skills:** {', '.join(p['skills'])}\n")

        if p.get("problem"):
            lines.append(f"\n### Business Problem\n\n{p['problem']}\n")
        if p.get("solution"):
            lines.append(f"\n### Solution\n\n{p['solution']}\n")
        if p.get("results"):
            lines.append(f"\n### Results\n\n{p['results']}\n")
        lines.append("")

    with open(filepath, "w") as f:
        f.write("\n".join(lines))

    print()
    print(colorize(f"  ✓  Exported {len(projects)} project{'s' if len(projects) != 1 else ''} to ", GREEN + BOLD) +
          colorize(str(filepath), CYAN))
    print()
    _footer()

# ── Filter (full-text search across all fields) ────────────────────────────────
def filter_projects(term):
    db       = load_db()
    projects = db["projects"]
    q        = term.lower()

    def matches(p):
        fields = [
            p.get("name", ""),
            p.get("client", ""),
            p.get("employer", ""),
            p.get("role", ""),
            p.get("industry", ""),
            p.get("problem", ""),
            p.get("solution", ""),
            p.get("results", ""),
            p.get("lessons", p.get("results", "")),
        ] + p.get("functionals", []) + p.get("skills", [])
        return any(q in f.lower() for f in fields)

    results = sorted(
        [p for p in projects if matches(p)],
        key=lambda p: (p["year"], p["month"])
    )

    print()
    print(colorize("  ◈  Filter: ", BOLD + WHITE) + colorize(term, BOLD + CYAN))
    divider()

    if not results:
        print(colorize(f"\n  No projects match '{term}'.\n", GRAY + DIM))
    else:
        for p in results:
            _print_compact(p)
        print()
        divider()
        print(colorize(f"  {len(results)} match{'es' if len(results) != 1 else ''}", GRAY))

    print()
    _footer()

