# ── Delete project ─────────────────────────────────────────────────────────────
def delete_project(pid):
    db    = load_db()
    match = next((p for p in db["projects"] if p["id"] == pid), None)
    if not match:
        print(colorize(f"\n  ✗  No project with id #{pid}.\n", RED))
        return
    print()
    confirm = input(
        colorize("  Delete ", GRAY) +
        colorize(f"#{pid} {match['name']}", BOLD + WHITE) +
        colorize("? y/N › ", GRAY)
    ).strip().lower()
    if confirm in ("y", "yes"):
        db["projects"] = [p for p in db["projects"] if p["id"] != pid]
        save_db(db)
        print(colorize(f"  ✓  #{pid} deleted.\n", GREEN))
    else:
        print(colorize("  Cancelled.\n", GRAY))
    _footer()

# ── Summary ────────────────────────────────────────────────────────────────────
def show_summary():
    db       = load_db()
    projects = db["projects"]

    print()
    print(colorize("  ◈  Experience Summary", BOLD + WHITE))
    divider()

    if not projects:
        print(colorize("\n  No projects yet.\n", GRAY + DIM))
        _footer()
        return

    skill_count = {}
    ind_count  = {}
    func_count = {}

    for p in projects:
        for t in p.get("skills", p.get("techs", [])):
            skill_count[t] = skill_count.get(t, 0) + 1
        ind_count[p["industry"]] = ind_count.get(p["industry"], 0) + 1
        for f in p["functionals"]:
            func_count[f] = func_count.get(f, 0) + 1

    total     = len(projects)
    clients   = len({p["client"] for p in projects})
    employers = len({p["employer"] for p in projects})

    print()
    print(f"  {colorize(str(total), BOLD + WHITE)} projects  "
          f"{colorize(str(clients), BOLD + CYAN)} clients  "
          f"{colorize(str(employers), BOLD + MAGENTA)} employers")

    def print_ranked(label, counts, color):
        if not counts:
            return
        print()
        print(colorize(f"  {label}", BOLD + WHITE))
        max_count = max(counts.values())
        col = max(32, max(len(n) for n in counts) + 2)
        for name, cnt in sorted(counts.items(), key=lambda x: -x[1]):
            bar = "█" * round((cnt / max_count) * 20)
            print(f"    {colorize(f'{name:<{col}}', color)}  {colorize(bar, color + DIM)}  {colorize(str(cnt), GRAY)}")

    print_ranked("Skills",     skill_count,  BLUE)
    print_ranked("Industries",       ind_count,   YELLOW)
    print_ranked("Functional Areas", func_count,  GREEN)

    print()
    _footer()

# ── Main ───────────────────────────────────────────────────────────────────────
def main():
    args = sys.argv[1:]

    if not args:
        show_main(); return

    if args[0] == "full":
        show_full(); return

    if args[0] == "summary":
        show_summary(); return

    if args[0] == "add":
        add_project(); return

    if args[0] == "export":
        export_projects(); return

    if args[0] == "filter":
        if len(args) < 2:
            print(colorize("\n  ✗  Provide a search term: xp filter <term>\n", RED))
            return
        filter_projects(" ".join(args[1:]))
        return


    if args[0] == "skill":
        list_taxonomy("skills"); return

    if args[0] == "industry":
        list_taxonomy("industries"); return

    if args[0] == "functional":
        if len(args) > 1 and args[1] == "add":
            add_taxonomy("functionals")
        else:
            list_taxonomy("functionals")
        return

    # xp <id> <action>
    if len(args) == 2:
        try:
            pid = int(args[0])
        except ValueError:
            print(colorize(f"\n  ✗  Unknown command: {' '.join(args)}\n", RED))
            _usage(); return
        cmd = args[1].lower()
        if cmd in ("delete", "del", "rm", "remove"):
            delete_project(pid)
        elif cmd == "edit":
            edit_project(pid)
        elif cmd in ("detail", "show", "view"):
            detail_project(pid)
        else:
            print(colorize(f"\n  ✗  Unknown action '{cmd}'. Use: detail | edit | delete\n", RED))
        return

    print(colorize(f"\n  ✗  Unknown command: {' '.join(args)}\n", RED))
    _usage()

def _usage():
    print(colorize("  Usage:", BOLD + WHITE))
    rows = [
        ("xp",                      "List all projects"),
        ("xp full",                 "All projects with full detail"),
        ("xp add",                  "Add a project"),
        ("xp filter <term>",        "Search across all fields"),
        ("xp export",               "Export all projects to .md"),
        ("xp summary",              "Stats overview"),
        ("xp <id> detail",          "Full detail of a project"),
        ("xp <id> edit",            "Edit a project"),
        ("xp <id> delete",          "Delete a project"),
        ("xp functional list",      "List functional areas"),
    ]
    for cmd, desc in rows:
        print(colorize(f"    {cmd:<30}", CYAN) + colorize(desc, GRAY))
    print()

if __name__ == "__main__":
    main()
