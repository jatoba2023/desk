.gantt-bar{{position:absolute;top:0;height:100%;border-radius:2px}}
.gantt-bar.done{{background:var(--green)}}.gantt-bar.planned{{background:var(--blue)}}.gantt-bar.late{{background:var(--red)}}
.gantt-bar.partial{{background:linear-gradient(90deg,var(--green) 0%,var(--green) 55%,var(--blue-l) 55%)}}
.today-line{{position:absolute;top:-4px;bottom:-4px;width:2px;background:var(--accent);z-index:10}}
.g-status{{width:80px;text-align:center}}
.status-pill{{display:inline-block;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;border-radius:2px;white-space:nowrap}}
.sp-done{{background:var(--green-l);color:var(--green)}}.sp-ok{{background:#eef4ff;color:var(--blue)}}.sp-late{{background:var(--red-l);color:var(--red)}}.sp-partial{{background:#fff8e6;color:#a07820}}
.legend-item{{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--gray-4);font-weight:500}}
.legend-swatch{{width:14px;height:8px;border-radius:1px}}
.chart-area{{display:flex;flex-direction:column;gap:14px}}
.bar-row{{display:flex;align-items:center;gap:12px}}
.bar-label{{width:160px;flex-shrink:0;font-size:12px;color:var(--navy);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}}
.bar-track{{flex:1;display:flex;flex-direction:column;gap:4px}}
.bar-fill{{height:14px;border-radius:1px;position:relative;min-width:2px}}
.bar-fill.previsto{{background:var(--gray-2)}}.bar-fill.realizado{{background:var(--blue)}}.bar-fill.late{{background:var(--red)}}
.bar-val{{position:absolute;right:-52px;top:50%;transform:translateY(-50%);font-size:10px;font-family:'IBM Plex Mono',monospace;color:var(--gray-4);white-space:nowrap}}
.data-table{{width:100%;border-collapse:collapse;font-size:13px}}
.data-table thead th{{font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--gray-3);padding:10px 16px;background:var(--gray-0);border-bottom:2px solid var(--gray-2);text-align:left;white-space:nowrap}}
.data-table thead th.num{{text-align:right}}
.data-table tbody td{{padding:11px 16px;border-bottom:1px solid var(--gray-1);color:var(--gray-5);vertical-align:middle}}
.data-table tbody tr:last-child td{{border-bottom:none}}
.data-table tbody tr:hover td{{background:var(--gray-0)}}
.data-table tbody td.num{{text-align:right;font-family:'IBM Plex Mono',monospace;font-size:12px}}
.data-table .subtotal td{{background:var(--gray-0);font-weight:600;color:var(--navy);border-top:1px solid var(--gray-2);border-bottom:1px solid var(--gray-2)}}
.data-table .total td{{background:var(--navy);color:var(--white);font-weight:600}}
.data-table .total td.num{{font-family:'IBM Plex Mono',monospace}}
.desvio{{font-family:'IBM Plex Mono',monospace;font-size:12px}}
.desvio.pos{{color:var(--red)}}.desvio.neg{{color:var(--green)}}.desvio.zer{{color:var(--gray-3)}}
.task-id{{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--gray-3);background:var(--gray-1);padding:2px 6px;border-radius:2px;margin-right:6px}}
.report-footer{{max-width:1100px;margin:0 auto;padding:20px 48px 40px;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--gray-3);border-top:1px solid var(--gray-2)}}
.footer-brand{{font-family:'Playfair Display',serif;font-size:13px;color:var(--navy)}}
</style>
</head>
<body>
<header class="report-header">
  <div class="header-inner">
    <div>
      <div class="header-eyebrow">Relatório Executivo · pln</div>
      <h1 class="header-title">{proj_name}</h1>
      <div class="header-sub">Projeto #{p["id"]} &nbsp;·&nbsp; Gerado automaticamente</div>
    </div>
    <div class="header-right">
      <div class="header-date">{gen_date}</div>
      <div class="header-status-badge">{status_label}</div>
    </div>
  </div>
</header>
<main class="report-body">
  <!-- KPIs -->
  <div class="kpi-grid">
    <div class="kpi {kpi_real_cls}">
      <div class="kpi-label">Custo Realizado</div>
      <div class="kpi-value">{brl(total_real)}</div>
      <div class="kpi-sub"><span class="kpi-delta flat">→</span> tarefas concluídas</div>
    </div>
    <div class="kpi kpi-gold">
      <div class="kpi-label">Custo Previsto Total</div>
      <div class="kpi-value">{brl(total_prev)}</div>
      <div class="kpi-sub"><span class="kpi-delta flat">→</span> orçamento do projeto</div>
    </div>
    <div class="kpi kpi-green">
      <div class="kpi-label">Progresso</div>
      <div class="kpi-value">{len(done_tasks)}/{len(tasks)}</div>
      <div class="kpi-sub"><span class="kpi-delta {'down' if prog_pct>=50 else 'up'}">{'▲' if prog_pct>=50 else '▼'} {prog_pct}%</span> concluído</div>
    </div>
    <div class="kpi {'kpi-red' if is_late else 'kpi-blue'}">
      <div class="kpi-label">Prazo-alvo</div>
      <div class="kpi-value">{target_d.strftime("%d %b")}</div>
      <div class="kpi-sub"><span class="kpi-delta {'up' if is_late else 'flat'}">{'⚠' if is_late else '→'}</span> {target_d.year}{late_tag}</div>
    </div>
  </div>
  <!-- Alertas -->
  <div class="alert-bar">
    <div class="alert-icon">⚠</div>
    <div class="alert-content">
      <div class="alert-title">Pontos de atenção</div>
      <div class="alert-items">{alert_chips()}</div>
    </div>
  </div>
  <!-- Resumo executivo -->
  <div class="card">
    <div class="card-header"><div class="card-title"><span class="dot"></span>Resumo Executivo</div><span class="card-tag">Síntese</span></div>
    <div class="card-body"><p class="exec-summary">{exec_sum}</p></div>
  </div>
  <!-- Gantt -->
  <div class="card">
    <div class="card-header"><div class="card-title"><span class="dot"></span>Cronograma</div><span class="card-tag">{gs.strftime("%b")} – {ge.strftime("%b %Y")}</span></div>
    <div class="card-body" style="padding-bottom:28px">
      {gantt_header()}
      <div class="gantt-wrap">
        <table class="gantt-table">
          <thead><tr><th class="g-id">#</th><th class="g-name">Tarefa</th><th style="width:100%">Linha do tempo</th><th class="g-status">Status</th></tr></thead>
          <tbody>{gantt_rows()}</tbody>
        </table>
      </div>
      <div style="display:flex;gap:20px;margin-top:16px;padding-top:12px;border-top:1px solid var(--gray-1)">
        <div class="legend-item"><div class="legend-swatch" style="background:var(--green)"></div>Concluída</div>
        <div class="legend-item"><div class="legend-swatch" style="background:linear-gradient(90deg,var(--green) 55%,var(--blue-l) 55%)"></div>Em andamento</div>
        <div class="legend-item"><div class="legend-swatch" style="background:var(--blue)"></div>Prevista</div>
        <div class="legend-item"><div class="legend-swatch" style="background:var(--red)"></div>Risco/Atraso</div>
        <div class="legend-item" style="margin-left:auto"><div style="width:2px;height:14px;background:var(--accent);border-radius:1px"></div>Hoje</div>
      </div>
    </div>
  </div>
  <!-- Previsto x Realizado -->
  <div class="card">
    <div class="card-header"><div class="card-title"><span class="dot"></span>Previsto × Realizado por Tarefa</div><span class="card-tag">Custo em R$</span></div>
    <div class="card-body">
      <div style="display:flex;gap:20px;margin-bottom:16px">
        <div class="legend-item"><div class="legend-swatch" style="background:var(--gray-2)"></div>Previsto</div>
        <div class="legend-item"><div class="legend-swatch" style="background:var(--blue)"></div>Realizado</div>
        <div class="legend-item"><div class="legend-swatch" style="background:var(--red)"></div>Acima do previsto</div>
