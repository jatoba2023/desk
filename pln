        <thead><tr><th>Recurso</th><th>Categoria</th><th class="num">Custo/dia</th><th>Tarefas</th><th class="num">Dias totais</th><th class="num">Custo previsto</th><th class="num">% total</th></tr></thead>
        <tbody>{resource_rows()}</tbody>
