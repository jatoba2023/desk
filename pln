# ── TUI: seleção de projeto ───────────────────────────────────────────────────────
def tui_select_project():
    """Tela de seleção/criação de projeto. Retorna o projeto escolhido ou None."""
    clear()
    db = load_db()
    W  = term_width()

    print()
    print(f"  {c('desk', BOLD + WHITE)} {c('·', GRAY)} {c('pln — Planejador de Projetos', CYAN + BOLD)}")
    print(c("  " + "─" * (W - 4), GRAY))
    print()

    projects = [p for p in db["projects"] if not p.get("archived")]
    archived = [p for p in db["projects"] if p.get("archived")]

    if not projects:
        print(c("  Nenhum projeto ativo.\n", GRAY))
    else:
        for i, p in enumerate(projects, 1):
            tasks  = p.get("tasks", [])
            done   = sum(1 for t in tasks if t.get("done"))
            total  = len(tasks)
            target = fmt_date(p.get("target_date", ""))
            bw     = 10
            filled = round(bw * done / total) if total else 0
            bar    = c("█" * filled, GREEN) + c("░" * (bw - filled), GRAY)
            late   = ""
            if p.get("target_date") and date.fromisoformat(p["target_date"]) < date.today() and done < total:
                late = c(" ATRASADO", RED + BOLD)
            print(f"  {c(str(i), CYAN + BOLD)}  {c(p['name'], BOLD + WHITE)}  "
                  f"{bar} {c(f'{done}/{total}', GRAY)}  "
                  f"{c('prazo:', GRAY)} {c(target, YELLOW)}{late}")
        print()

    if archived:
        print(c(f"  {len(archived)} projeto(s) arquivado(s)", GRAY + DIM))
        print()

    print(f"  {c('N', CYAN + BOLD)}  Novo projeto")
    print(f"  {c('A', CYAN + BOLD)}  Arquivar projeto")
    if archived:
        print(f"  {c('D', CYAN + BOLD)}  Desarquivar projeto")
    print(f"  {c('S', CYAN + BOLD)}  Sair")
    print()

    while True:
        raw = input(c("  Escolha › ", CYAN + BOLD)).strip().lower()
        if raw in ("s", "sair", "exit", "q"):
            return None
        if raw in ("n", "novo", "new"):
            clear()
            print()
            print(c("  ◆  Novo Projeto", BOLD + WHITE))
            print(c("  Ctrl+C para cancelar.\n", GRAY))
            name   = prompt("Nome do projeto")
            target = prompt_date("Data-alvo (prazo final)")
            db2    = load_db()
            pid    = next_pid(db2)
            db2["projects"].append({
                "id": pid, "name": name, "target_date": target,
                "tasks": [], "recursos": []
            })
            save_db(db2)
            return get_project(db2, pid)
        if raw in ("a", "arquivar") and projects:
            clear()
            print()
            print(c("  ◆  Arquivar Projeto", BOLD + WHITE))
            print(c("  Projeto arquivado não aparece na tela inicial.\n", GRAY))
            for i, p in enumerate(projects, 1):
                print(f"  {c(str(i), CYAN + BOLD)}  {c(p['name'], WHITE)}")
            print()
            raw2 = input(c("  Qual projeto arquivar? (número ou Enter para cancelar) › ", CYAN + BOLD)).strip()
            if raw2:
                try:
                    idx2 = int(raw2) - 1
                    if 0 <= idx2 < len(projects):
                        db2 = load_db()
                        p2  = get_project(db2, projects[idx2]["id"])
                        if p2:
                            p2["archived"] = True
                            save_db(db2)
                            print(c(f"  ✓  '{p2['name']}' arquivado.", GREEN))
                            import time; time.sleep(1)
                except (ValueError, IndexError):
                    pass
            return tui_select_project()
        if raw in ("d", "desarquivar") and archived:
            clear()
            print()
            print(c("  ◆  Desarquivar Projeto", BOLD + WHITE))
            print()
            for i, p in enumerate(archived, 1):
                target = fmt_date(p.get("target_date", ""))
                print(f"  {c(str(i), CYAN + BOLD)}  {c(p['name'], WHITE)}  {c(target, GRAY)}")
            print()
            raw2 = input(c("  Qual projeto restaurar? (número ou Enter para cancelar) › ", CYAN + BOLD)).strip()
            if raw2:
                try:
                    idx2 = int(raw2) - 1
                    if 0 <= idx2 < len(archived):
                        db2 = load_db()
                        p2  = get_project(db2, archived[idx2]["id"])
                        if p2:
                            p2["archived"] = False
                            save_db(db2)
                            print(c(f"  ✓  '{p2['name']}' restaurado.", GREEN))
                            import time; time.sleep(1)
                except (ValueError, IndexError):
                    pass
            return tui_select_project()
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(projects):
                db2 = load_db()
                return get_project(db2, projects[idx]["id"])
        except: pass
        print(c("  ✗  Opção inválida.", RED))

# ── TUI: shell persistente ────────────────────────────────────────────────────────
def tui_shell(project):
    """Loop principal do shell TUI. Redesenha a tela a cada comando."""
    pid = project["id"]
    msg       = ""
    msg_color = GREEN

    while True:
        # Sempre recarrega do disco para refletir mudanças
        db = load_db()
        p  = get_project(db, pid)
        if not p:
            print(c("\n  Projeto não encontrado. Saindo.\n", RED))
            return

        draw_screen(p, msg, msg_color)
        msg = ""

        try:
            raw = input(c(f"  pln #{pid} › ", CYAN + BOLD)).strip()
        except (KeyboardInterrupt, EOFError):
            clear()
            print(c("\n  Até logo.\n", GRAY))
            return

        if not raw:
            continue

        args = raw.split()
        cmd  = args[0].lower()

        # ── Sair ────────────────────────────────────────────────────────────────
        if cmd in ("sair", "exit", "q", "quit"):
            clear()
            print(c("\n  Até logo.\n", GRAY))
            return

        # ── Voltar à lista de projetos ───────────────────────────────────────────
        if cmd in ("projetos", "voltar", "back"):
            new_p = tui_select_project()
            if new_p is None:
                clear()
                print(c("\n  Até logo.\n", GRAY))
                return
            pid = new_p["id"]
            msg = f"Projeto #{pid} '{new_p['name']}' carregado."
            continue

        # ── Editar projeto ───────────────────────────────────────────────────────
        if cmd == "edit" and len(args) == 1:
            draw_screen(p, "")
            print(c(f"\n  ◆  Editar Projeto #{pid}", BOLD + WHITE))
            print(c("  Enter para manter.\n", GRAY))
            raw_name   = input(c("  Nome", CYAN + BOLD) + c(f" [{p['name']}]", GRAY) + c(" › ", GRAY)).strip()
            raw_target = input(c("  Data-alvo", CYAN + BOLD) + c(f" [{p['target_date']}]", GRAY) + c(" › ", GRAY)).strip()
            db2 = load_db(); p2 = get_project(db2, pid)
            if raw_name:   p2["name"] = raw_name
            if raw_target:
                try:    p2["target_date"] = date.fromisoformat(raw_target).isoformat()
                except: pass
            save_db(db2)
            msg = "Projeto atualizado."; continue

        # ── Recurso ──────────────────────────────────────────────────────────────
        if cmd == "recurso":
            sub = args[1] if len(args) > 1 else ""
            if sub == "add":
                draw_screen(p, "")
                print(c(f"\n  ◆  Novo Recurso\n", BOLD + WHITE))
                name   = prompt("Nome")
                print()
                print(c("  Categoria:", BOLD + WHITE))
                idx    = prompt_choice("Categoria", CATEGORIAS)
                cat    = CATEGORIAS[idx]
                custo  = prompt_float("Custo por dia (R$)", hint="ex: 500 ou 250.50")
                db2    = load_db(); p2 = get_project(db2, pid)
                rid    = next_rid(p2)
                p2.setdefault("recursos", []).append({"id": rid, "name": name, "categoria": cat, "custo_dia": custo})
                save_db(db2)
                msg = f"Recurso R{rid} '{name}' adicionado. {fmt_brl(custo)}/dia"
            elif sub == "list":
                draw_screen(p, "")
                recursos = p.get("recursos", [])
                if not recursos:
                    print(c("\n  Nenhum recurso cadastrado.", GRAY))
                else:
                    print()
                    for cat in CATEGORIAS:
                        items = [r for r in recursos if r.get("categoria") == cat]
                        if not items: continue
                        col = cat_color(cat)
                        print(c(f"  {cat}", col + BOLD))
                        for r in items:
                            print(f"    {c(f'R{r["id"]}', col + BOLD)}  {c(r['name'], WHITE)}  {c(fmt_brl(r.get('custo_dia',0))+'/dia', GRAY)}")
                        print()
                input(c("  Enter para continuar › ", GRAY))
                msg = ""
            elif sub == "delete" and len(args) > 2:
                try:
                    rid = int(args[2])
                    db2 = load_db(); p2 = get_project(db2, pid)
                    r   = get_resource(p2, rid)
                    if not r:
                        msg = f"Recurso R{rid} não encontrado."; msg_color = RED; continue
                    draw_screen(p2, "")
                    confirm = input(c(f"\n  Apagar R{rid} '{r['name']}'? s/N › ", GRAY)).strip().lower()
                    if confirm in ("s","sim","y","yes"):
                        p2["recursos"] = [x for x in p2["recursos"] if x["id"] != rid]
                        for t in p2.get("tasks", []):
                            t["recursos"] = [x for x in t.get("recursos", []) if (x["rid"] if isinstance(x, dict) else x) != rid]
                        save_db(db2)
                        msg = f"Recurso R{rid} removido."
                    else:
                        msg = "Cancelado."
                except ValueError:
                    msg = "Use: recurso delete <n>"; msg_color = RED
            else:
                msg = "Comandos: recurso add · recurso list · recurso delete <n>"; msg_color = YELLOW
            continue

        # ── Task ─────────────────────────────────────────────────────────────────
        if cmd == "task":
            sub = args[1] if len(args) > 1 else ""

            if sub == "add":
                draw_screen(p, "")
                print(c(f"\n  ◆  Nova Tarefa\n", BOLD + WHITE))
                name    = prompt("Nome da tarefa")
                dur     = prompt_float("Duração (dias)", hint="ex: 5  10  3")
                preds   = prompt_predecessors([t for t in p.get("tasks", [])])
                db2     = load_db(); p2 = get_project(db2, pid)
                res_recs = _prompt_recursos(p2, db=db2, pid=pid)
                db2     = load_db(); p2 = get_project(db2, pid)  # reload after possible inline add
                print()
                use_win = input(c("  Definir janela de datas? (s/N) › ", CYAN + BOLD)).strip().lower()
                ws, we  = (None, None)
                if use_win in ("s","sim","y","yes"):
                    ws, we = prompt_window()
                tid      = next_tid(p2)
                task_obj = {
                    "id": tid, "name": name, "duration_days": dur,
                    "predecessors": preds, "recursos": res_recs, "done": False
                }
                if ws: task_obj["window_start"] = ws
                if we: task_obj["window_end"]   = we
                p2.setdefault("tasks", []).append(task_obj)
                save_db(db2)
                sched2 = schedule(p2)
                s2     = sched2.get(tid, {})
                msg    = f"T{tid} '{name}' criada · {fmt_date(s2.get('start'))} → {fmt_date(s2.get('end'))} · {fmt_brl(task_cost(p2['tasks'][-1], p2))}"
                continue

            # task <n> <verb>
            if len(args) >= 3:
                try:
                    tid  = int(args[1])
                    verb = args[2].lower()
                except (ValueError, IndexError):
                    msg = "Use: task <n> edit|done|delete"; msg_color = RED; continue

                db2 = load_db(); p2 = get_project(db2, pid)
                t   = get_task(p2, tid)
                if not t:
                    msg = f"T{tid} não encontrada."; msg_color = RED; continue

                if verb == "done":
                    if t.get("done"):
                        msg = f"T{tid} já está concluída."; msg_color = YELLOW
                    else:
                        old_sched = schedule(p2)
                        today2    = date.today()
                        s_old     = old_sched.get(tid, {})
                        t["done"]         = True
                        t["completed_on"] = today2.isoformat()
                        t["started_on"]   = d2s(s_old.get("start")) or today2.isoformat()
                        save_db(db2)
                        new_sched = schedule(p2)
                        shifted   = [tx for tx in p2.get("tasks", [])
                                     if any(pr.get("tid") == tid for pr in tx.get("predecessors", []))
                                     and not tx.get("done")
                                     and d2s(old_sched.get(tx["id"],{}).get("start")) != d2s(new_sched.get(tx["id"],{}).get("start"))]
                        msg = f"T{tid} '{t['name']}' concluída."
                        if shifted:
                            msg += "  Recalculado: " + ", ".join(f"T{tx['id']}" for tx in shifted)

                elif verb == "edit":
                    draw_screen(p2, "")
                    print(c(f"\n  ◆  Editar T{tid} — {t['name']}\n", BOLD + WHITE))
                    raw_name = input(c("  Nome", CYAN + BOLD) + c(f" [{t['name']}]", GRAY) + c(" › ", GRAY)).strip()
                    raw_dur  = input(c("  Duração (dias)", CYAN + BOLD) + c(f" [{t['duration_days']}]", GRAY) + c(" › ", GRAY)).strip()
                    if raw_name: t["name"] = raw_name
                    if raw_dur:
                        try: t["duration_days"] = float(raw_dur.replace(",","."))
                        except: pass
                    tasks_other       = [x for x in p2.get("tasks", []) if x["id"] != tid]
                    t["predecessors"] = prompt_predecessors(tasks_other, current=t.get("predecessors", []))
                    t["recursos"]     = _prompt_recursos(p2, current_recs=t.get("recursos", []), db=db2, pid=pid)
                    # Janela
                    print()
                    has_win  = t.get("window_start") or t.get("window_end")
                    cur_ws   = t.get("window_start","")
                    cur_we   = t.get("window_end","")
                    if has_win:
                        print(c(f"  Janela atual: {cur_ws or chr(8212)} → {cur_we or chr(8212)}", GRAY))
                    edit_win = input(c("  Editar janela de datas? (s/N) › ", CYAN + BOLD)).strip().lower()
                    if edit_win in ("s","sim","y","yes"):
                        ws, we = prompt_window(current_ws=cur_ws, current_we=cur_we)
                        if ws: t["window_start"] = ws
                        else:  t.pop("window_start", None)
                        if we: t["window_end"]   = we
                        else:  t.pop("window_end", None)
                    save_db(db2)
                    sched2 = schedule(p2); s2 = sched2.get(tid, {})
                    msg    = f"T{tid} '{t['name']}' atualizada · {fmt_date(s2.get('start'))} → {fmt_date(s2.get('end'))}"

                elif verb == "delete":
                    draw_screen(p2, "")
                    confirm = input(c(f"\n  Apagar T{tid} '{t['name']}'? s/N › ", GRAY)).strip().lower()
                    if confirm in ("s","sim","y","yes"):
                        p2["tasks"] = [x for x in p2["tasks"] if x["id"] != tid]
                        for tx in p2["tasks"]:
                            tx["predecessors"] = [pr for pr in tx.get("predecessors", []) if pr.get("tid") != tid]
                        save_db(db2)
                        msg = f"T{tid} apagada."
                    else:
                        msg = "Cancelado."
                else:
                    msg = "Verbos válidos: edit · done · delete"; msg_color = YELLOW
                continue

            msg = "Use: task add · task <n> edit · task <n> done · task <n> delete"
            msg_color = YELLOW
            continue

        # ── Report ───────────────────────────────────────────────────────────────
        if cmd == "report":
            db2 = load_db(); p2 = get_project(db2, pid)
            out = cmd_report(p2)
            msg = f"Relatório gerado: {out}"
            msg_color = GREEN
            continue

        # ── Comando desconhecido ──────────────────────────────────────────────────
        msg       = f"Comando desconhecido: '{raw}'"
        msg_color = RED

# ── Main ─────────────────────────────────────────────────────────────────────────
def main():
    # Modo legado: aceita argumentos de linha de comando (compatibilidade)
    args = sys.argv[1:]
    if args:
        _legacy_main(args)
        return

    # Modo TUI interativo
    try:
        p = tui_select_project()
        if p:
            tui_shell(p)
        else:
            clear()
            print(c("\n  Até logo.\n", GRAY))
    except KeyboardInterrupt:
        clear()
        print(c("\n  Até logo.\n", GRAY))

def _legacy_main(args):
    """Mantém compatibilidade com comandos antigos: pln <id> gantt, etc."""
    if args == ["add"]:
        cmd_add_project(); return
    try:
        pid = int(args[0])
    except ValueError:
        print(c(f"\n  ✗  Use apenas 'pln' para abrir o modo interativo.\n", YELLOW))
        return
    rest = args[1:]
    if not rest:             cmd_project(pid);  return
    if rest == ["gantt"]:    cmd_gantt(pid);    return
    if rest == ["edit"]:     cmd_edit_project(pid); return
    if rest == ["delete"]:   cmd_delete_project(pid); return
    if rest[0] == "recurso":
        sub = rest[1:]
        if sub == ["add"]:   cmd_add_recurso(pid);   return
        if sub == ["list"]:  cmd_list_recursos(pid); return
        if len(sub) == 2 and sub[1] == "delete":
            try: cmd_delete_recurso(pid, int(sub[0])); return
            except ValueError: pass
    if rest[0] == "task":
        sub = rest[1:]
        if sub == ["add"]: cmd_add_task(pid); return
        if len(sub) == 2:
            try:
                tid = int(sub[0])
                if sub[1] == "edit":   cmd_edit_task(pid, tid);   return
                if sub[1] == "done":   cmd_done_task(pid, tid);   return
                if sub[1] == "delete": cmd_delete_task(pid, tid); return
            except ValueError: pass
    print(c(f"\n  ✗  Comando desconhecido: {' '.join(args)}\n", RED))

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        clear()
        print(c("\n  Até logo.\n", GRAY))
