#!/usr/bin/env python3
# pln — Planejador de Projetos · desk ecosystem

import json, os, sys
from datetime import date, timedelta
from pathlib import Path

PLN_FILE = Path.home() / ".pln.json"

# ── ANSI ────────────────────────────────────────────────────────────────────────
RESET="\033[0m"; BOLD="\033[1m"; DIM="\033[2m"
RED="\033[91m"; YELLOW="\033[93m"; GREEN="\033[92m"
CYAN="\033[96m"; MAGENTA="\033[95m"; WHITE="\033[97m"; GRAY="\033[90m"

def c(text, *codes): return "".join(codes) + text + RESET
def term_width():
    try: return os.get_terminal_size().columns
    except: return 100

CATEGORIAS  = ["Mão de Obra", "Equipamento", "Insumos"]
CAT_COLORS  = [CYAN, YELLOW, GREEN]
MESES       = ["","Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"]

def cat_color(cat):
    try: return CAT_COLORS[CATEGORIAS.index(cat)]
    except: return GRAY

# ── Persistência + migração ──────────────────────────────────────────────────────
def migrate_predecessors(project):
    """Migrate old flat list [1,2] to new format [{"tid":1,"tipo":"FI","lag":0}]"""
    for t in project.get("tasks", []):
        preds = t.get("predecessors", [])
        if preds and isinstance(preds[0], (int, float)):
            t["predecessors"] = [
                {"tid": int(p), "tipo": "FI", "lag": 0} for p in preds
            ]

def migrate_units(project):
    """Migrate duration_weeks→duration_days (*7), custo_semana→custo_dia (/7),
       and task recursos flat list → [{"rid": id, "qty": 1}]."""
    for t in project.get("tasks", []):
        if "duration_weeks" in t:
            t["duration_days"] = round(t.pop("duration_weeks") * 7, 2)
        recs = t.get("recursos", [])
        if recs and not isinstance(recs[0], dict):
            t["recursos"] = [{"rid": int(r), "qty": 1} for r in recs]
    for r in project.get("recursos", []):
        if "custo_semana" in r:
            r["custo_dia"] = round(r.pop("custo_semana") / 7, 2)

def load_db():
    if PLN_FILE.exists():
        with open(PLN_FILE) as f:
            db = json.load(f)
        for p in db.get("projects", []):
            migrate_predecessors(p)
            migrate_units(p)
        return db
    return {"projects": []}

def save_db(db):
    with open(PLN_FILE, "w") as f:
        json.dump(db, f, indent=2, ensure_ascii=False)

def next_pid(db):
    return max((p["id"] for p in db["projects"]), default=0) + 1

def next_tid(project):
    return max((t["id"] for t in project.get("tasks", [])), default=0) + 1

def next_rid(project):
    return max((r["id"] for r in project.get("recursos", [])), default=0) + 1

def get_project(db, pid):
    return next((p for p in db["projects"] if p["id"] == pid), None)

def get_task(project, tid):
    return next((t for t in project.get("tasks", []) if t["id"] == tid), None)

def get_resource(project, rid):
    return next((r for r in project.get("recursos", []) if r["id"] == rid), None)

# ── Prompts ──────────────────────────────────────────────────────────────────────
def prompt(label, required=True, hint="", default=""):
    d = f" {c(f'[{default}]', GRAY)}" if default else ""
    h = f"  {c(hint, GRAY)}" if hint else ""
    while True:
        val = input(c(f"  {label}", CYAN + BOLD) + d + c(" › ", GRAY)).strip()
        if val: return val
        if default: return default
        if not required: return ""
        print(c("  ✗  Campo obrigatório.", RED))

def prompt_float(label, hint="", default=None):
    d_str = str(default) if default is not None else ""
    while True:
        raw = prompt(label, hint=hint, default=d_str)
        try: return float(raw.replace(",", "."))
        except: print(c("  ✗  Digite um número válido (ex: 1.5 ou 2)", RED))

def prompt_date(label, hint="AAAA-MM-DD", default=""):
    while True:
        raw = prompt(label, hint=hint, default=default)
        try:
            return date.fromisoformat(raw).isoformat()
        except:
            print(c("  ✗  Data inválida. Use AAAA-MM-DD.", RED))

def prompt_choice(label, options):
    for i, o in enumerate(options, 1):
        print(f"  {c(str(i), CYAN + BOLD)}  {o}")
    print()
    while True:
        raw = input(c(f"  {label}", CYAN + BOLD) + c(" › ", GRAY)).strip()
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(options): return idx
        except: pass
        print(c(f"  ✗  Digite um número entre 1 e {len(options)}.", RED))


def prompt_window(current_ws=None, current_we=None):
    """
    Ask for optional window_start / window_end.
    Returns (ws_iso|None, we_iso|None).
    """
    print()
    ws_d = current_ws or ""
    we_d = current_we or ""
    hint = "AAAA-MM-DD ou Enter para nenhuma"

    raw_ws = input(
        c("  Janela: início mínimo", CYAN + BOLD) +
        (c(f" [{ws_d}]", GRAY) if ws_d else c(" [sem restrição]", GRAY)) +
        c(" › ", GRAY)
    ).strip()
    raw_we = input(
        c("  Janela: fim máximo   ", CYAN + BOLD) +
        (c(f" [{we_d}]", GRAY) if we_d else c(" [sem restrição]", GRAY)) +
        c(" › ", GRAY)
    ).strip()

    def parse(raw, current):
        if not raw: return current or None
        if raw in ("-", "0", "none", "nenhuma", "remover"): return None
        try:    return date.fromisoformat(raw).isoformat()
        except: print(c("  ✗  Data inválida, ignorada.", YELLOW)); return current or None

    return parse(raw_ws, current_ws), parse(raw_we, current_we)

def prompt_predecessors(tasks_other, current=None):
    """
    Interactive predecessor builder.
    Returns list of {"tid": int, "tipo": "FI"|"II", "lag": float}
    """
    if not tasks_other:
        return []

    print()
    print(c("  Tarefas disponíveis:", GRAY))
    for i, t in enumerate(tasks_other, 1):
        print(f"  {c(str(i), CYAN + BOLD)}  T{t['id']} — {t['name']}")
    print()

    if current:
        cur_str = "  ".join(fmt_pred(p) for p in current)
        print(c(f"  Predecessoras atuais: {cur_str}", GRAY))
        raw = input(c("  Selecione (ex: 1,3 ou Enter para manter) › ", CYAN + BOLD)).strip()
        if not raw:
            return current
    else:
        raw = input(c("  Selecione predecessoras (ex: 1,3 ou Enter para nenhuma) › ", CYAN + BOLD)).strip()
        if not raw:
            return []

    selected = []
    for part in raw.split(","):
        try:
            idx = int(part.strip()) - 1
            if 0 <= idx < len(tasks_other):
                selected.append(tasks_other[idx])
        except: pass

    if not selected:
        return []

    preds = []
    for t in selected:
        print()
        print(c(f"  Relação com T{t['id']} — {t['name']}:", BOLD + WHITE))
        print(f"  {c('1', CYAN + BOLD)}  FI — Fim→Início  {c('(B começa quando A termina)', GRAY)}")
        print(f"  {c('2', CYAN + BOLD)}  II — Início→Início  {c('(B começa quando A começa)', GRAY)}")
        print()
        tipo_idx = prompt_choice("Tipo de relação", ["FI", "II"])
        tipo     = ["FI", "II"][tipo_idx]

        lag_raw = input(
            c("  Lag (dias)", CYAN + BOLD) +
            c(" [0]  ", GRAY) +
            c("positivo=atraso  negativo=sobreposição › ", GRAY)
        ).strip()
        try:
            lag = float(lag_raw.replace(",", ".")) if lag_raw else 0.0
        except:
            lag = 0.0

        preds.append({"tid": t["id"], "tipo": tipo, "lag": lag})

    return preds

def fmt_pred(p):
    """Format a predecessor dict for display."""
    lag = p.get("lag", 0)
    lag_str = ""
    if lag > 0:   lag_str = c(f" +{lag}d", YELLOW)
    elif lag < 0: lag_str = c(f" {lag}d",  GREEN)
    tipo_col = CYAN if p["tipo"] == "FI" else MAGENTA
    return c(str(p["tid"]), BOLD) + c(f"[{p['tipo']}]", tipo_col) + lag_str

# ── Scheduling (ALAP + FI/II + lag) ─────────────────────────────────────────────
def days_to_days(d): return d

def schedule(project):
    """
    ALAP scheduling with FI/II relationship types and lag.
    Also applies window constraints (window_start / window_end) after ALAP.

    Returns {tid: {"start": date, "end": date, "conflict": str|None}}
    conflict is set when the window forces a date outside ALAP range.
    """
    tasks  = project.get("tasks", [])
    target = date.fromisoformat(project["target_date"])
    if not tasks:
        return {}

    tid_map = {t["id"]: t for t in tasks}

    # Build successor map: {tid: [(succ_tid, pred_obj)]}
    successors = {t["id"]: [] for t in tasks}
    for t in tasks:
        for p in t.get("predecessors", []):
            pred_tid = p["tid"] if isinstance(p, dict) else int(p)
            if pred_tid in successors:
                successors[pred_tid].append((t["id"], p))

    # Topological sort
    def topo_sort():
        visited, order = set(), []
        def visit(tid):
            if tid in visited: return
            visited.add(tid)
            for s, _ in successors[tid]: visit(s)
            order.append(tid)
        for t in tasks: visit(t["id"])
        return list(reversed(order))

    order = topo_sort()

    latest_start = {}
    latest_end   = {}
    sched        = {}

    for tid in reversed(order):
        t   = tid_map[tid]
        dur = timedelta(days=round(days_to_days(t["duration_days"])))

        # Done task: use actual dates
        if t.get("done") and t.get("completed_on") and t.get("started_on"):
            s = date.fromisoformat(t["started_on"])
            e = date.fromisoformat(t["completed_on"])
            latest_start[tid] = s
            latest_end[tid]   = e
            sched[tid]        = {"start": s, "end": e}
            continue

        succs = successors[tid]  # list of (succ_tid, pred_obj)

        if not succs:
            # No successors: end at target
            e = target
            s = e - dur
        else:
            # Compute latest allowed start/end based on each successor's constraint
            candidates_end   = []  # latest allowed end for this task
            candidates_start = []  # latest allowed start (from II constraints)

            for succ_tid, pred_obj in succs:
                if succ_tid not in latest_start:
                    continue
                tipo = pred_obj.get("tipo", "FI") if isinstance(pred_obj, dict) else "FI"
                lag  = pred_obj.get("lag", 0)     if isinstance(pred_obj, dict) else 0
                lag_days = timedelta(days=round(days_to_days(lag)))

                if tipo == "FI":
                    # end(A) + lag = start(B)  →  end(A) = start(B) - lag
                    candidates_end.append(latest_start[succ_tid] - lag_days)
                elif tipo == "II":
                    # start(A) + lag = start(B)  →  start(A) = start(B) - lag
                    candidates_start.append(latest_start[succ_tid] - lag_days)

            if candidates_end:
                e = min(candidates_end)
                s = e - dur
            elif candidates_start:
                s = min(candidates_start)
                e = s + dur
            else:
                e = target
                s = e - dur

            # If we got both constraints, take the most restrictive
            if candidates_end and candidates_start:
                e_from_end   = min(candidates_end)
                s_from_end   = e_from_end - dur
                s_from_start = min(candidates_start)
                # ALAP: pick whichever gives the later (but still valid) start
                s = min(s_from_end, s_from_start)
                e = s + dur

        latest_start[tid] = s
        latest_end[tid]   = e
        sched[tid]        = {"start": s, "end": e, "conflict": None}

    # ── Apply window constraints ──────────────────────────────────────────────
    for t in tasks:
        tid = t["id"]
        if tid not in sched: continue
        ws_raw = t.get("window_start")
        we_raw = t.get("window_end")
        if not ws_raw and not we_raw: continue

        entry   = sched[tid]
        s, e    = entry["start"], entry["end"]
        dur     = e - s
        conflicts = []

        if ws_raw:
            ws = date.fromisoformat(ws_raw) if isinstance(ws_raw, str) else ws_raw
            if s < ws:
                conflicts.append(f"início forçado para {fmt_date(ws)} (janela)")
                s = ws
                e = s + dur
        if we_raw:
            we = date.fromisoformat(we_raw) if isinstance(we_raw, str) else we_raw
            if e > we:
                conflicts.append(f"fim forçado para {fmt_date(we)} (janela)")
                e = we
                s = e - dur

        entry["start"]    = s
        entry["end"]      = e
        entry["conflict"] = "  |  ".join(conflicts) if conflicts else None
        latest_start[tid] = s
        latest_end[tid]   = e

    return sched

# ── Formatação ───────────────────────────────────────────────────────────────────
def fmt_date(val):
    if not val: return "—"
    if isinstance(val, date): d = val
    else:
        try: d = date.fromisoformat(val)
        except: return "—"
    return f"{d.day:02d} {MESES[d.month]} {d.year}"

def fmt_brl(v):
    return f"R$ {v:,.2f}".replace(",","X").replace(".",",").replace("X",".")

def task_cost(task, project):
    total = 0.0
    for rec in task.get("recursos", []):
        rid = rec["rid"] if isinstance(rec, dict) else int(rec)
        qty = rec.get("qty", 1) if isinstance(rec, dict) else 1
        r   = get_resource(project, rid)
        if r:
            total += r.get("custo_dia", 0) * qty * task.get("duration_days", 0)
    return total

def project_cost(project):
    return sum(task_cost(t, project) for t in project.get("tasks", []))

def task_res_names(task, project):
    """Returns list of 'Name (×N)' strings for a task's resources."""
    names = []
    for rec in task.get("recursos", []):
        rid = rec["rid"] if isinstance(rec, dict) else int(rec)
        qty = rec.get("qty", 1) if isinstance(rec, dict) else 1
        r   = get_resource(project, rid)
        if r:
            names.append(r["name"] + (f" (×{qty})" if qty > 1 else ""))
    return names

def d2s(d):
    """date to isoformat safely."""
    return d.isoformat() if isinstance(d, date) else d

