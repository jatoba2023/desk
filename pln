def cmd_list():
    db = load_db()
    W  = term_width()
    print()
    print(c("  desk", BOLD + WHITE) + c(" · ", GRAY) + c("pln", CYAN + BOLD))
    print(c("  " + "─" * (W - 4), GRAY))

    if not db["projects"]:
        print(c("  Nenhum projeto encontrado.\n", GRAY))
        print(c("  ", GRAY) + c("pln add", CYAN) + c("  para criar um projeto.\n", GRAY))
        return

    for p in db["projects"]:
        tasks  = p.get("tasks", [])
        done   = sum(1 for t in tasks if t.get("done"))
        total  = len(tasks)
        target = fmt_date(p.get("target_date", ""))
        cost   = project_cost(p)

        bar_w  = 16
        filled = round(bar_w * done / total) if total else 0
        bar    = c("█" * filled, GREEN) + c("░" * (bar_w - filled), GRAY)

        late = ""
        if p.get("target_date"):
            td = date.fromisoformat(p["target_date"])
            if td < date.today() and done < total:
                late = c("  ATRASADO", RED + BOLD)

        pid_str = p['id']
        pname   = p['name']
        print(f"  {c(f'#{pid_str}', CYAN + BOLD)}  {c(pname, BOLD + WHITE)}")
        print(f"     {bar}  {c(f'{done}/{total} tarefas', GRAY)}  ·  "
              f"{c('Prazo:', GRAY)} {c(target, YELLOW)}{late}")
        print(f"     {c('Custo estimado:', GRAY)} {c(fmt_brl(cost), GREEN)}")
        print()

    print(c("  pln add", CYAN) + c("  ·  ", GRAY) +
          c("pln <id>", CYAN) + c("  ·  ", GRAY) +
          c("pln <id> gantt", CYAN))
    print()

# ── Detalhe do projeto ───────────────────────────────────────────────────────────
def cmd_project(pid):
    db = load_db()
    p  = get_project(db, pid)
    if not p:
        print(c(f"\n  ✗  Projeto #{pid} não encontrado.\n", RED)); return

    W     = term_width()
    tasks = p.get("tasks", [])
    done  = sum(1 for t in tasks if t.get("done"))
    total = len(tasks)
    sched = schedule(p)

    print()
    print(c(f"  #{p['id']} {p['name']}", BOLD + WHITE))
    print(c("  " + "─" * (W - 4), GRAY))
    print(f"  {c('Prazo-alvo:', GRAY)}  {c(fmt_date(p.get('target_date','')), YELLOW + BOLD)}")
    print(f"  {c('Progresso:', GRAY)}   {c(f'{done}/{total} tarefas concluídas', WHITE)}")
    print(f"  {c('Custo total:', GRAY)} {c(fmt_brl(project_cost(p)), GREEN + BOLD)}")
    print()

    # Recursos
    recursos = p.get("recursos", [])
    if recursos:
        print(c("  Recursos", BOLD + WHITE))
        for r in recursos:
            col = cat_color(r.get("categoria", ""))
            rid_str = r['id']
            print(f"    {c(f'R{rid_str}', col + BOLD)}  {c(r['name'], WHITE)}"
                  f"  {c(r.get('categoria',''), col + DIM)}"
                  f"  {c(fmt_brl(r.get('custo_dia',0)) + '/dia', GRAY)}")
        print()

    # Tarefas
    if not tasks:
        print(c("  Nenhuma tarefa ainda.\n", GRAY))
    else:
        print(c("  Tarefas", BOLD + WHITE))
        for t in sorted(tasks, key=lambda t: ((sched.get(t['id']) or {}).get('start') or date.max, t['id'])):
            s       = sched.get(t["id"], {})
            ts_str  = fmt_date(s.get("start"))
            te_str  = fmt_date(s.get("end"))
            done_mk = c("✓", GREEN + BOLD) if t.get("done") else c("○", GRAY)

            # Predecessoras formatadas
            preds    = t.get("predecessors", [])
            pred_str = ("  após: " + "  ".join(fmt_pred(p2) for p2 in preds)) if preds else ""

            res_names = task_res_names(t, p)
            res_str = c("  " + ", ".join(res_names), CYAN + DIM) if res_names else ""
            cost_str = c(f"  {fmt_brl(task_cost(t,p))}", GRAY)

            late = ""
            if s.get("end") and not t.get("done"):
                end_d = s["end"] if isinstance(s["end"], date) else date.fromisoformat(s["end"])
                if end_d > date.fromisoformat(p["target_date"]):
                    late = c("  ⚠ fora do prazo", RED)

            tid_str  = t['id']
            dur_str  = f"{t['duration_days']}d"
            print(f"  {done_mk} {c(f'T{tid_str}', BOLD + WHITE)}  {t['name']}"
                  f"  {c(dur_str, YELLOW)}"
                  f"{c(pred_str, GRAY)}{res_str}{cost_str}{late}")
            print(f"       {c(ts_str, GRAY)} → {c(te_str, GRAY)}")
        print()

    print(c("  pln <id> task add", CYAN) + c("  ·  ", GRAY) +
          c("pln <id> gantt", CYAN) + c("  ·  ", GRAY) +
          c("pln <id> edit", CYAN) + c("  ·  ", GRAY) +
          c("pln <id> delete", CYAN))
    print()

# ── Gantt ────────────────────────────────────────────────────────────────────────
def cmd_gantt(pid):
    db = load_db()
    p  = get_project(db, pid)
    if not p:
        print(c(f"\n  ✗  Projeto #{pid} não encontrado.\n", RED)); return

    tasks  = p.get("tasks", [])
    if not tasks:
        print(c("\n  Nenhuma tarefa para exibir.\n", GRAY)); return

    sched  = schedule(p)
    target = date.fromisoformat(p["target_date"])
    today  = date.today()
    W      = term_width()

    # Date range
    all_dates = []
    for s in sched.values():
        if s.get("start"): all_dates.append(s["start"] if isinstance(s["start"], date) else date.fromisoformat(s["start"]))
        if s.get("end"):   all_dates.append(s["end"]   if isinstance(s["end"],   date) else date.fromisoformat(s["end"]))
    if not all_dates: return
    chart_start = min(all_dates)
    chart_end   = max(all_dates + [target])
    total_days  = max((chart_end - chart_start).days + 1, 1)

    LABEL_W = min(26, W // 4)
    BAR_W   = max(W - LABEL_W - 18, 20)

    print()
    print(c(f"  #{p['id']} {p['name']}", BOLD + WHITE) +
          c(f"  ·  Gantt  ·  prazo: {fmt_date(p['target_date'])}", GRAY))
    print(c("  " + "─" * (W - 4), GRAY))

    # Week header
    hdr = ""
    cur = chart_start
    while cur <= chart_end:
        pos = round((cur - chart_start).days / total_days * BAR_W)
        lbl = f"{cur.day:02d}/{MESES[cur.month]}"
        while len(hdr) < pos: hdr += " "
        hdr += lbl
        cur += timedelta(days=7)
    print(c(" " * (LABEL_W + 7) + hdr[:BAR_W], GRAY))
    print(c("  " + "─" * (W - 4), GRAY))

    today_pos  = round((today  - chart_start).days / total_days * BAR_W) if chart_start <= today  <= chart_end else -1
    target_pos = round((target - chart_start).days / total_days * BAR_W) if 0 <= round((target - chart_start).days / total_days * BAR_W) < BAR_W else BAR_W - 1

    for t in tasks:
        s = sched.get(t["id"], {})
        if not s: continue
        ts = s["start"] if isinstance(s["start"], date) else date.fromisoformat(s["start"])
        te = s["end"]   if isinstance(s["end"],   date) else date.fromisoformat(s["end"])

        bar_s = round((ts - chart_start).days / total_days * BAR_W)
        bar_e = max(round((te - chart_start).days / total_days * BAR_W), bar_s + 1)

        bar = [" "] * BAR_W
        for i in range(bar_s, min(bar_e, BAR_W)):
            bar[i] = "█"
        if 0 <= today_pos < BAR_W:
            bar[today_pos] = "▎" if bar[today_pos] == " " else bar[today_pos]
        if 0 <= target_pos < BAR_W:
            bar[target_pos] = "◆"

        is_done = t.get("done", False)
        is_late = te > target and not is_done

        bar_str = ""
        for i, ch in enumerate(bar):
            if ch == "█":
                if is_done:             bar_str += c(ch, GREEN)
                elif is_late and i >= target_pos: bar_str += c(ch, RED)
                else:                   bar_str += c(ch, CYAN)
            elif ch == "▎": bar_str += c(ch, RED + BOLD)
            elif ch == "◆": bar_str += c(ch, YELLOW + BOLD)
            else:           bar_str += ch

        done_mk  = c("✓", GREEN + BOLD) if is_done else c("○", GRAY)
        label    = t["name"][:LABEL_W - 1].ljust(LABEL_W)
        dur_str  = c(f"{t['duration_days']}d", YELLOW)
