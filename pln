def cmd_done_task(pid, tid):
    db = load_db()
    p  = get_project(db, pid)
    if not p:
        print(c(f"\n  ✗  Projeto #{pid} não encontrado.\n", RED)); return
    t = get_task(p, tid)
    if not t:
        print(c(f"\n  ✗  Tarefa T{tid} não encontrada.\n", RED)); return
    if t.get("done"):
        print(c(f"\n  T{tid} já está concluída.\n", YELLOW)); return

    old_sched = schedule(p)
    today     = date.today()
    s_old     = old_sched.get(tid, {})

    t["done"]         = True
    t["completed_on"] = today.isoformat()
    t["started_on"]   = d2s(s_old.get("start")) or today.isoformat()
    save_db(db)

    new_sched = schedule(p)
    print()
    print(c(f"  ✓  T{tid} '{t['name']}' concluída em {fmt_date(today.isoformat())}.", GREEN + BOLD))

    # Report shifted dependents
    shifted = []
    for tx in p.get("tasks", []):
        if any(pr.get("tid") == tid for pr in tx.get("predecessors", [])) and not tx.get("done"):
            old_s = old_sched.get(tx["id"], {})
            new_s = new_sched.get(tx["id"], {})
            if d2s(old_s.get("start")) != d2s(new_s.get("start")):
                shifted.append((tx, old_s, new_s))
    if shifted:
        print(c("\n  Prazos recalculados:", YELLOW))
        for tx, old_s, new_s in shifted:
            print(f"    T{tx['id']} {tx['name']}: "
                  f"{c(fmt_date(old_s.get('start')), GRAY)} → {c(fmt_date(new_s.get('start')), CYAN)}")
    print()

