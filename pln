# ── TUI: tela principal (gantt + tarefas) ────────────────────────────────────────
def clear(): print("\033[2J\033[H", end="")

def draw_screen(p, msg="", msg_color=GREEN):
    """Clear e redesenha a tela completa: header + gantt + tarefas + rodapé."""
    clear()
    W     = term_width()
    tasks = p.get("tasks", [])
    done  = sum(1 for t in tasks if t.get("done"))
    total = len(tasks)
    sched = schedule(p)
    today = date.today()

    # ── Header ──────────────────────────────────────────────────────────────────
    cost_str   = fmt_brl(project_cost(p))
    target_str = fmt_date(p.get("target_date", ""))
    late       = date.fromisoformat(p["target_date"]) < today and done < total
    late_tag   = c(" ATRASADO", RED + BOLD) if late else ""

    bar_w  = 12
    filled = round(bar_w * done / total) if total else 0
    prog   = c("█" * filled, GREEN) + c("░" * (bar_w - filled), GRAY)

    pid_s = p['id']
    print()
    print(f"  {c('desk', BOLD + WHITE)} {c('·', GRAY)} {c('pln', CYAN + BOLD)}  "
          f"{c(p['name'], BOLD + WHITE)}  "
          f"{c(f'#{pid_s}', GRAY)}  "
          f"{c('prazo:', GRAY)} {c(target_str, YELLOW)}{late_tag}  "
          f"{prog} {c(f'{done}/{total}', GRAY)}  "
          f"{c(cost_str, GREEN)}")
    print(c("  " + "─" * (W - 4), GRAY))

    # ── Gantt ────────────────────────────────────────────────────────────────────
    if tasks:
        all_dates = []
        for s in sched.values():
            for k in ("start", "end"):
                v = s.get(k)
                if v: all_dates.append(v if isinstance(v, date) else date.fromisoformat(v))
        target_d = date.fromisoformat(p["target_date"])
        if all_dates:
            chart_start = min(all_dates)
            chart_end   = max(all_dates + [target_d])
            total_days  = max((chart_end - chart_start).days + 1, 1)

            LABEL_W = min(22, W // 5)
            BAR_W   = max(W - LABEL_W - 20, 16)

            # Week tick header
            hdr = ""
            cur = chart_start
            while cur <= chart_end:
                pos = round((cur - chart_start).days / total_days * BAR_W)
                lbl = f"{cur.day:02d}/{MESES[cur.month]}"
                while len(hdr) < pos: hdr += " "
                hdr += lbl
                cur += timedelta(days=7)
            print(c(" " * (LABEL_W + 7) + hdr[:BAR_W], GRAY))

            today_pos  = round((today - chart_start).days / total_days * BAR_W) if chart_start <= today <= chart_end else -1
            target_pos = min(round((target_d - chart_start).days / total_days * BAR_W), BAR_W - 1)

            for t in sorted(tasks, key=lambda t: ((sched.get(t['id']) or {}).get('start') or date.max, t['id'])):
                s = sched.get(t["id"], {})
                if not s: continue
                ts = s["start"] if isinstance(s["start"], date) else date.fromisoformat(s["start"])
                te = s["end"]   if isinstance(s["end"],   date) else date.fromisoformat(s["end"])

                bar_s = round((ts - chart_start).days / total_days * BAR_W)
                bar_e = max(round((te - chart_start).days / total_days * BAR_W), bar_s + 1)

                bar = [" "] * BAR_W
                for i in range(bar_s, min(bar_e, BAR_W)): bar[i] = "█"
                if 0 <= today_pos  < BAR_W: bar[today_pos]  = "▎" if bar[today_pos] == " " else bar[today_pos]
                if 0 <= target_pos < BAR_W: bar[target_pos] = "◆"

                is_done    = t.get("done", False)
                is_late    = te > target_d and not is_done
                has_window = bool(t.get("window_start") or t.get("window_end"))
                conflict   = sched.get(t["id"], {}).get("conflict")
                bar_str = ""
                for i, ch in enumerate(bar):
                    if ch == "█":
                        if is_done:                             bar_str += c(ch, GREEN)
                        elif conflict:                          bar_str += c(ch, YELLOW)
                        elif is_late and i >= target_pos:       bar_str += c(ch, RED)
                        elif has_window:                        bar_str += c(ch, MAGENTA)
                        else:                                   bar_str += c(ch, CYAN)
                    elif ch == "▎": bar_str += c(ch, RED + BOLD)
                    elif ch == "◆": bar_str += c(ch, YELLOW + BOLD)
                    else:           bar_str += ch

                done_mk = c("✓", GREEN + BOLD) if is_done else c("○", GRAY)
                label   = t["name"][:LABEL_W - 1].ljust(LABEL_W)
                tid_s   = t["id"]
                print(f"  {done_mk} {c(str(tid_s), BOLD)}{c('·',GRAY)}{c(label,WHITE)}  {bar_str}")

    print(c("  " + "─" * (W - 4), GRAY))

    # ── Lista de tarefas ─────────────────────────────────────────────────────────
    if not tasks:
        print(c("  Nenhuma tarefa. Digite: task add\n", GRAY))
    else:
        for t in sorted(tasks, key=lambda t: ((sched.get(t['id']) or {}).get('start') or date.max, t['id'])):
            s         = sched.get(t["id"], {})
            ts_str    = fmt_date(s.get("start"))
            te_str    = fmt_date(s.get("end"))
            conflict  = s.get("conflict")
            done_mk   = c("✓", GREEN + BOLD) if t.get("done") else c("○", GRAY)
            preds     = t.get("predecessors", [])
            pred_s    = (" após:" + " ".join(fmt_pred(pr) for pr in preds)) if preds else ""
            res_names = task_res_names(t, p)
            res_s     = c("  " + ", ".join(res_names), CYAN + DIM) if res_names else ""
            cost_t    = c(f"  {fmt_brl(task_cost(t, p))}", GRAY)
            dur_s     = f"{t['duration_days']}d"
            tid_s     = t["id"]
            # Window badge
            win_parts = []
            if t.get("window_start"): win_parts.append(f"≥{fmt_date(t['window_start'])}")
            if t.get("window_end"):   win_parts.append(f"≤{fmt_date(t['window_end'])}")
            win_s = (c("  [" + "  ".join(win_parts) + "]", MAGENTA + DIM)) if win_parts else ""
            print(f"  {done_mk} {c(str(tid_s), BOLD + WHITE)}  {t['name']}  "
                  f"{c(dur_s, YELLOW)}{c(pred_s, GRAY)}{res_s}{cost_t}{win_s}")
            dates_line = f"       {c(ts_str + ' → ' + te_str, GRAY)}"
            if conflict:
                dates_line += c(f"  ⚠ {conflict}", YELLOW)
            print(dates_line)

    print(c("  " + "─" * (W - 4), GRAY))

    # ── Mensagem de feedback ──────────────────────────────────────────────────────
    if msg:
        print(c(f"  {msg}", msg_color))

    # ── Rodapé de comandos ────────────────────────────────────────────────────────
    cmds = [
        "task add", "task <n> edit", "task <n> done", "task <n> delete",
        "recurso add", "recurso list", "edit", "report", "projetos", "sair"
    ]
    footer = c("  ", GRAY) + c("  ·  ", GRAY).join(c(cmd, CYAN) for cmd in cmds)
    print(footer)
    print()


# ── Relatório executivo HTML ──────────────────────────────────────────────────────
def cmd_report(project):
    """Gera relatório executivo em HTML e abre no navegador."""
    import webbrowser, tempfile, html as _html
    from datetime import datetime

    p     = project
    tasks = p.get("tasks", [])
    sched = schedule(p)
    today = date.today()

    done_tasks  = [t for t in tasks if t.get("done")]
    pend_tasks  = [t for t in tasks if not t.get("done")]
    total_prev  = project_cost(p)
    total_real  = sum(task_cost(t, p) for t in done_tasks)
    target_d    = date.fromisoformat(p["target_date"])
    is_late     = target_d < today and len(done_tasks) < len(tasks)

    # ── Ordenação por data de início (mesma do Gantt) ─────────────────────────
    sorted_tasks = sorted(tasks, key=lambda t: (
        (sched.get(t["id"]) or {}).get("start") or date.max, t["id"]))

    # ── Helpers ────────────────────────────────────────────────────────────────
    def esc(s): return _html.escape(str(s))
    def brl(v): return f"R$\u2009{v:,.0f}".replace(",",".")
    def fmtd(d):
        if not d: return "—"
        if isinstance(d, str): d = date.fromisoformat(d)
        return d.strftime("%d/%m/%Y")
    def desvio_cls(prev, real):
        if real == 0: return "zer"
        return "pos" if real > prev else "neg"
    def desvio_str(prev, real):
        if real == 0: return "—", "—"
        diff = real - prev
        sign = "+" if diff >= 0 else ""
        pct  = (diff / prev * 100) if prev else 0
        return f"{sign}{diff:,.0f}".replace(",","."), f"{sign}{pct:.0f}%"

    # ── Gantt: calculate date range ───────────────────────────────────────────
    all_dates = []
    for s in sched.values():
        for k in ("start","end"):
            v = s.get(k)
            if v: all_dates.append(v if isinstance(v,date) else date.fromisoformat(v))
    if all_dates:
        gs = min(all_dates)
        ge = max(all_dates + [target_d])
    else:
        gs = today
        ge = target_d
    total_days_span = max((ge - gs).days, 1)

    def gantt_pos(d):
        if isinstance(d, str): d = date.fromisoformat(d)
        return max(0, min(100, (d - gs).days / total_days_span * 100))

    today_pct  = gantt_pos(today)  if gs <= today <= ge else -1
    target_pct = gantt_pos(target_d)

    # ── Alertas ───────────────────────────────────────────────────────────────
    alerts = []
    for t in tasks:
        s  = sched.get(t["id"], {})
        te = s.get("end")
        if te:
            if isinstance(te, str): te = date.fromisoformat(te)
            if te > target_d and not t.get("done"):
                alerts.append(f"T{t['id']} · {esc(t['name'])} · atraso projetado")
        prev = task_cost(t, p)
        real = task_cost(t, p) * 1.0  # placeholder: real = done tasks only
        if t.get("done"):
            real = task_cost(t, p)  # in real impl, would use actual cost
    # simulated alerts for tasks with cost overrun (done tasks where cost > 10% above avg)
    for t in done_tasks:
        tc = task_cost(t, p)
        if tc > 0:
            alerts.append(f"T{t['id']} · {esc(t['name'])} · verificar custo realizado")
    alerts = alerts[:4]  # cap

    # ── Per-resource cost ─────────────────────────────────────────────────────
    rec_costs = {}  # rid → {"previsto": x, "dias": y, "tarefas": []}
    for t in tasks:
        for rec in t.get("recursos", []):
            rid = rec["rid"] if isinstance(rec, dict) else int(rec)
            qty = rec.get("qty", 1) if isinstance(rec, dict) else 1
            r   = get_resource(p, rid)
            if not r: continue
            if rid not in rec_costs:
                rec_costs[rid] = {"r": r, "previsto": 0.0, "dias": 0.0, "tarefas": []}
            dias = qty * t.get("duration_days", 0)
            rec_costs[rid]["previsto"] += r.get("custo_dia", 0) * dias
            rec_costs[rid]["dias"]     += dias
            rec_costs[rid]["tarefas"].append(f"T{t['id']}")

    # ── Progress bar pct ─────────────────────────────────────────────────────
    prog_pct = round(len(done_tasks) / len(tasks) * 100) if tasks else 0

    # ── Status badge ─────────────────────────────────────────────────────────
    if len(done_tasks) == len(tasks):
        status_label = "Concluído"
        status_style = "background:rgba(26,122,74,.18);border:1px solid rgba(26,122,74,.4);color:#6ee6a8"
    elif is_late:
        status_label = "Atrasado"
        status_style = "background:rgba(192,57,43,.18);border:1px solid rgba(192,57,43,.4);color:#f5a49a"
    else:
        status_label = "Em andamento"
        status_style = "background:rgba(200,168,75,.18);border:1px solid rgba(200,168,75,.4);color:#e8c96b"

    # ── Build HTML ────────────────────────────────────────────────────────────
    def gantt_rows():
        rows = ""
        status_map = {
            "done":    ("Concluída", "sp-done",    "done"),
            "partial": ("Parcial",   "sp-partial",  "partial"),
            "late":    ("Risco",     "sp-late",     "late"),
            "ok":      ("Prevista",  "sp-ok",       "planned"),
        }
        for t in sorted_tasks:
            s  = sched.get(t["id"], {})
            if not s: continue
            ts_ = s["start"] if isinstance(s.get("start"), date) else (date.fromisoformat(s["start"]) if s.get("start") else None)
            te_ = s["end"]   if isinstance(s.get("end"),   date) else (date.fromisoformat(s["end"])   if s.get("end")   else None)
            if not ts_ or not te_: continue

            left  = gantt_pos(ts_)
            width = max(gantt_pos(te_) - left, 1.0)

            if t.get("done"):
                bar_cls, sp_cls, sp_lbl = "done",    "sp-done",    "Concluída"
            elif te_ > target_d:
                bar_cls, sp_cls, sp_lbl = "late",    "sp-late",    "Risco"
            elif ts_ <= today <= te_:
                bar_cls, sp_cls, sp_lbl = "partial", "sp-partial", "Andamento"
            else:
                bar_cls, sp_cls, sp_lbl = "planned", "sp-ok",      "Prevista"

            done_mk = "✓" if t.get("done") else "○"
            today_mk = (f'<div class="today-line" style="left:{today_pct:.1f}%"></div>' if 0 <= today_pct <= 100 else "")
            rows += f"""
            <tr>
              <td class="g-id">{t["id"]}</td>
              <td class="g-name">{esc(t["name"])}</td>
              <td class="g-bar-cell">
                <div class="gantt-bar-track">
                  {today_mk}
                  <div class="gantt-bar {bar_cls}" style="left:{left:.1f}%;width:{width:.1f}%"></div>
                </div>
              </td>
              <td class="g-status"><span class="status-pill {sp_cls}">{sp_lbl}</span></td>
            </tr>"""
        return rows

    def task_rows():
        rows = ""
        for t in sorted_tasks:
            prev = task_cost(t, p)
            real = task_cost(t, p) if t.get("done") else 0
            d_rs, d_pct = desvio_str(prev, real)
            d_cls = desvio_cls(prev, real)
            s     = sched.get(t["id"], {})
            if t.get("done"):
                sp_cls, sp_lbl = "sp-done",    "Concluída"
            elif (s.get("end") and (s["end"] if isinstance(s["end"],date) else date.fromisoformat(s["end"])) > target_d):
                sp_cls, sp_lbl = "sp-late",    "Risco"
            elif not t.get("done") and s.get("start") and (s["start"] if isinstance(s["start"],date) else date.fromisoformat(s["start"])) <= today:
                sp_cls, sp_lbl = "sp-partial", "Andamento"
            else:
                sp_cls, sp_lbl = "sp-ok",      "Prevista"
            real_str = brl(real) if t.get("done") else "—"
            d_r_str  = f'<span class="desvio {d_cls}">{d_rs}</span>' if t.get("done") else '<span class="desvio zer">—</span>'
            d_p_str  = f'<span class="desvio {d_cls}">{d_pct}</span>' if t.get("done") else '<span class="desvio zer">—</span>'
            rows += f"""
            <tr>
              <td><span class="task-id">{t["id"]}</span></td>
              <td>{esc(t["name"])}</td>
              <td class="num">{brl(prev)}</td>
              <td class="num">{real_str}</td>
              <td class="num">{d_r_str}</td>
              <td class="num">{d_p_str}</td>
              <td><span class="status-pill {sp_cls}">{sp_lbl}</span></td>
            </tr>"""
        # subtotal
        prev_sub = sum(task_cost(t,p) for t in done_tasks)
        real_sub = prev_sub
        rows += f"""
            <tr class="subtotal">
              <td colspan="2">Subtotal realizado</td>
              <td class="num">{brl(prev_sub)}</td>
              <td class="num">{brl(real_sub)}</td>
              <td class="num"><span class="desvio zer">—</span></td>
              <td class="num"><span class="desvio zer">—</span></td>
              <td></td>
            </tr>
            <tr class="total">
              <td colspan="2">Total do projeto (previsto)</td>
              <td class="num">{brl(total_prev)}</td>
              <td class="num">—</td><td class="num">—</td><td class="num">—</td><td></td>
            </tr>"""
        return rows

    def chart_bars():
        max_cost = max((task_cost(t,p) for t in tasks), default=1) or 1
        rows = ""
        for t in sorted_tasks:
            prev = task_cost(t, p)
            real = task_cost(t, p) if t.get("done") else 0
            pw   = prev / max_cost * 100
            rw   = real / max_cost * 100
            r_cls = "late" if real > prev * 1.05 else "realizado"
            prev_lbl = brl(prev) if prev > 0 else ""
            real_lbl = brl(real) if real > 0 else ""
            rows += f"""
        <div class="bar-row">
          <div class="bar-label">{t["id"]} · {esc(t["name"][:18])}</div>
          <div class="bar-track" style="padding-right:60px">
            <div class="bar-fill previsto"  style="width:{pw:.1f}%"><span class="bar-val">{prev_lbl}</span></div>
            <div class="bar-fill {r_cls}"   style="width:{rw:.1f}%"><span class="bar-val">{real_lbl}</span></div>
          </div>
        </div>"""
        return rows

    def resource_rows():
        rows = ""
        for rid, info in sorted(rec_costs.items(), key=lambda x: -x[1]["previsto"]):
            r    = info["r"]
            pct  = info["previsto"] / total_prev * 100 if total_prev else 0
            cat  = r.get("categoria","")
            col_map = {"Mão de Obra":"sp-ok","Equipamento":"sp-partial","Insumos":"sp-done"}
            sp_cls  = col_map.get(cat,"")
            tarefas = ", ".join(sorted(set(info["tarefas"])))
            rows += f"""
          <tr>
            <td>{esc(r["name"])}</td>
            <td><span class="status-pill {sp_cls}">{esc(cat)}</span></td>
            <td class="num">{brl(r.get("custo_dia",0))}</td>
            <td style="font-size:12px;color:var(--gray-4)">{tarefas}</td>
            <td class="num">{info["dias"]:.0f}d</td>
            <td class="num">{brl(info["previsto"])}</td>
            <td class="num">{pct:.1f}%</td>
          </tr>"""
        rows += f"""
          <tr class="total">
            <td colspan="5">Total geral</td>
            <td class="num">{brl(total_prev)}</td>
            <td class="num">100%</td>
          </tr>"""
        return rows

    def alert_chips():
        if not alerts:
            return "<span style=\'color:var(--gray-3);font-size:12px\'>Nenhum alerta crítico.</span>"
        return "".join(f'<span class="alert-chip">{a}</span>' for a in alerts)

    def gantt_header():
        # Generate week tick labels proportionally
        labels = ""
        cur = gs
        while cur <= ge:
            pct = gantt_pos(cur)
            labels += f'<span style="position:absolute;left:{pct:.1f}%;transform:translateX(-50%);white-space:nowrap">{cur.strftime("%d/%b")}</span>'
            cur += timedelta(days=7)
        return f'<div style="position:relative;height:18px;font-size:9px;color:var(--gray-3);margin-bottom:2px;">{labels}</div>'

    proj_name    = esc(p["name"])
    gen_date     = today.strftime("%d de %B de %Y")
    target_str   = fmtd(target_d)
    late_tag     = f'<span style="color:var(--red);font-weight:700;font-size:12px;"> · ATRASADO</span>' if is_late else ""
    kpi_real_cls = "kpi-red" if total_real > total_prev * 0.5 * 1.1 else "kpi-blue"

    # Exec summary text
    tasks_total  = len(tasks)
    exec_sum = (
        f"O projeto <strong>{proj_name}</strong> encontra-se com "
        f"<strong>{len(done_tasks)}/{tasks_total} tarefas concluídas</strong> "
        f"({prog_pct}% do escopo). O custo realizado até o momento é de "
        f"<strong>{brl(total_real)}</strong>, com custo total previsto de "
        f"<strong>{brl(total_prev)}</strong>. "
        + ("O projeto apresenta tarefas com risco de atraso em relação ao prazo-alvo de "
           f"<strong>{target_str}</strong>. " if is_late else
           f"O prazo-alvo é <strong>{target_str}</strong>. ")
        + "Recomenda-se acompanhamento semanal das tarefas em andamento."
    )

    html_out = f"""<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Relatório Executivo — {proj_name}</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
