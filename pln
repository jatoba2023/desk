def _prompt_recursos(p, current_recs=None, db=None, pid=None):
    """
    Prompt for resource allocation with quantity support.
    p            : project dict (may be stale; db/pid used to reload after inline add)
    current_recs : list of {"rid": id, "qty": n} (for edit mode)
    Returns      : list of {"rid": id, "qty": n}
    """
    # Ask if user wants resources at all
    print()
    has_rec = input(c("  Associar recursos? (s/N) › ", CYAN + BOLD)).strip().lower()
    if has_rec not in ("s","sim","y","yes"):
        return []

    # Loop: allow inline resource creation
    while True:
        recursos = p.get("recursos", [])
        if not recursos:
            print(c("  Nenhum recurso cadastrado neste projeto.", GRAY))
            criar = input(c("  Criar um recurso agora? (s/N) › ", CYAN + BOLD)).strip().lower()
            if criar not in ("s","sim","y","yes"):
                return []
            # Inline resource creation
            print()
            name  = prompt("Nome do recurso")
            print()
            print(c("  Categoria:", BOLD + WHITE))
            idx   = prompt_choice("Categoria", CATEGORIAS)
            cat   = CATEGORIAS[idx]
            custo = prompt_float("Custo por dia (R$)", hint="ex: 500 ou 250.50")
            if db is not None and pid is not None:
                db2  = load_db()
                p2   = get_project(db2, pid)
                rid  = next_rid(p2)
                p2.setdefault("recursos", []).append({"id": rid, "name": name, "categoria": cat, "custo_dia": custo})
                save_db(db2)
                p["recursos"] = p2["recursos"]  # refresh local ref
            else:
                rid = next_rid(p)
                p.setdefault("recursos", []).append({"id": rid, "name": name, "categoria": cat, "custo_dia": custo})
            print(c(f"  ✓  R{rid} '{name}' criado.", GREEN))
            continue  # re-show list

        # Show available resources
        print()
        print(c("  Recursos disponíveis:", GRAY))
        for i, r in enumerate(recursos, 1):
            col = cat_color(r.get("categoria",""))
            rn  = r["name"]
            print(f"  {c(str(i), CYAN + BOLD)}  {c(rn, WHITE)}  "
                  f"{c(r.get('categoria',''), col + DIM)}  "
                  f"{c(fmt_brl(r.get('custo_dia',0))+'/dia', GRAY)}")
        print(f"  {c('N', CYAN + BOLD)}  Criar novo recurso")
        print()

        if current_recs:
            print(c("  Recursos atuais:", GRAY))
            for j, rec in enumerate(current_recs, 1):
                r2   = get_resource(p, rec["rid"])
                rn   = r2["name"] if r2 else "?"
                qty  = rec.get("qty", 1)
                col  = cat_color(r2.get("categoria","")) if r2 else GRAY
                print(f"    {c(str(j), MAGENTA + BOLD)}  {c(rn, WHITE)}  {c(f'×{qty}', YELLOW)}")
            print()
            print(c("  Enter  = manter todos  |  nova seleção pelos números da lista acima  |  0 = remover todos", GRAY + DIM))
            raw = input(c("  Selecione recursos (ex: 1,3 ou Enter para manter) › ", CYAN + BOLD)).strip()
            if not raw:
                # Offer per-item qty edit
                updated = []
                for rec in current_recs:
                    r2  = get_resource(p, rec["rid"])
                    rn  = r2["name"] if r2 else "?"
                    qty = rec.get("qty", 1)
                    qr  = input(c(f"  Qtd '{rn}' ", CYAN + BOLD) + c(f"[{qty}] › ", GRAY)).strip()
                    try:    qty = max(1, int(qr)) if qr else qty
                    except: pass
                    updated.append({"rid": rec["rid"], "qty": qty})
                return updated
            if raw == "0":
                return []
        else:
            raw = input(c("  Selecione (ex: 1,3 ou Enter para nenhum) › ", CYAN + BOLD)).strip()
            if not raw:
                return []

        if raw.lower() == "n":
            # Inline create then re-loop
            print()
            name  = prompt("Nome do recurso")
            print()
            print(c("  Categoria:", BOLD + WHITE))
            idx   = prompt_choice("Categoria", CATEGORIAS)
            cat   = CATEGORIAS[idx]
            custo = prompt_float("Custo por dia (R$)", hint="ex: 500 ou 250.50")
            if db is not None and pid is not None:
                db2  = load_db()
                p2   = get_project(db2, pid)
                rid  = next_rid(p2)
                p2.setdefault("recursos", []).append({"id": rid, "name": name, "categoria": cat, "custo_dia": custo})
                save_db(db2)
                p["recursos"] = p2["recursos"]
            else:
                rid = next_rid(p)
                p.setdefault("recursos", []).append({"id": rid, "name": name, "categoria": cat, "custo_dia": custo})
            print(c(f"  ✓  R{rid} '{name}' criado.", GREEN))
            current_recs = None  # reset so we ask fresh
            continue

        # Parse selections and ask qty for each
        result = []
        for part in raw.split(","):
            try:
                idx = int(part.strip()) - 1
                if 0 <= idx < len(recursos):
                    r   = recursos[idx]
                    qty_raw = input(
                        c(f"  Quantidade de '{r['name']}' ", CYAN + BOLD) +
                        c("[1] › ", GRAY)
                    ).strip()
                    try:
                        qty = int(qty_raw) if qty_raw else 1
                        qty = max(1, qty)
                    except:
                        qty = 1
                    result.append({"rid": r["id"], "qty": qty})
            except: pass
        return result

def cmd_add_task(pid):
    db = load_db()
    p  = get_project(db, pid)
    if not p:
        print(c(f"\n  ✗  Projeto #{pid} não encontrado.\n", RED)); return
    print()
    print(c(f"  ◆  Nova Tarefa — Projeto #{pid} {p['name']}", BOLD + WHITE))
